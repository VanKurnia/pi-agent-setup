# SUBAGENT CONFIGURATION
# Model overrides — uncomment and set to pin agents to specific models
RESEARCHER_MODEL=anthropic/claude-sonnet-4-6
SCOUT_MODEL=anthropic/claude-haiku-4-6
WORKER_MODEL=anthropic/claude-sonnet-4-6

# Max concurrent subagent executions (default: 4)
SUBAGENTS_MAX_CONCURRENCY=4
