# Subagent model assignments
# These control which model each subagent type uses.
# Uncomment and set to override defaults.
# RESEARCHER_MODEL=reason
# SCOUT_MODEL=assistant
# WORKER_MODEL=coder

# Maximum concurrent subagents (default: 8)
# SUBAGENTS_MAX_CONCURRENCY=8

# pi-fff file finder mode (default: override)
# PI_FFF_MODE=override
